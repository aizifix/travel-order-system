{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",
    "outDir": ".server-build",
    "rootDir": ".",
    "isolatedModules": false,
    "incremental": false,
    "verbatimModuleSyntax": false
  },
  "include": [
    "server.ts",
    "app/src/server/websocket/**/*.ts",
    "app/src/server/auth/session.ts",
    "app/src/server/auth/types.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
